# Wasome Website Environment Variables

# ========================================================
# Host & Docker Configuration
# ========================================================

# The port Nginx is exposed on (mapped to port 80 inside the container)
# Change this if port 8080 is already allocated on your host system.
PORT=8080

# The container runtime to use for compilation sandboxes (runsc or runc)
DOCKER_RUNTIME=runsc

# ========================================================
# Frontend (Vite/Svelte) Environment Variables
# ========================================================

# The public site key for Cloudflare Turnstile (used by the browser widget)
# For local testing, use the dummy key which always passes.
PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA


# ========================================================
# Backend (Rust/Axum) Environment Variables
# ========================================================

# The secret key for Cloudflare Turnstile (backend verification)
# For local testing with the dummy site key, use:
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Server bind address
BIND_ADDR=0.0.0.0:3000

# Path to the Wasome compiler installation on the host
HOST_WASOME_DIR=/root/.wasome

# Rate limiting (configurable per IP)
RATE_LIMIT_MAX_TOKENS=10
RATE_LIMIT_REFILL_PERIOD=900


# ========================================================
# Discord Webhook Notifications
# ========================================================
# The attack detection system sends alerts to these webhooks.
# Each level can use a different webhook, or all the same one.
# Leave empty to disable webhook notifications for that level.

# WARNING level (score >= 50): suspicious activity detected
DISCORD_WEBHOOK_ALERT=

# CRITICAL level (score >= 100): likely attack, IP auto-banned 1 hour
DISCORD_WEBHOOK_CRITICAL=

# EMERGENCY level (score >= 200): severe attack, IP auto-banned 24 hours
DISCORD_WEBHOOK_EMERGENCY=


# ========================================================
# Feature Toggles
# ========================================================

# Set to 'false' to disable compilation entirely.
# This hides the playground page and run buttons from the frontend.
COMPILATION_ENABLED=true

# Set to 'true' to enable maintenance mode.
# All compile endpoints return 503 and the frontend shows a maintenance notice.
MAINTENANCE_MODE=false


# ========================================================
# Admin API
# ========================================================

# Secret key required for the POST /api/admin/toggle endpoint.
# This allows toggling maintenance_mode and compilation_enabled at runtime.
# Leave empty to disable the admin endpoint.
ADMIN_SECRET=
